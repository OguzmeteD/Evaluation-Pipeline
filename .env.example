# Core OpenAI / model configuration
OPENAI_API_KEY=your_openai_api_key
EXPERIMENT_TASK_MODEL=openai:gpt-4.1-mini
EXPERIMENT_JUDGE_MODEL=openai:gpt-4.1
PROMPT_COACH_MODEL=openai:gpt-4.1

# Langfuse configuration
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PROJECT_ID=your_langfuse_project_id
LANGFUSE_TIMEOUT_SECONDS=60
LANGFUSE_SCORE_PAGE_SIZE=50
LANGFUSE_API_RETRIES=2

# App history / run storage
DATABASE_URL=postgresql://user:password@localhost:5432/evalpipeline
# POSTGRES_DSN=postgresql://user:password@localhost:5432/evalpipeline

# LiteLLM request log source
LITELLM_DATABASE_URL=postgresql://user:password@localhost:5432/litellm
LITELLM_DB_TIMEOUT_SECONDS=30
LITELLM_AUTO_CREATE_TABLE=true

# Canonical code-first table defaults
# Default table: litellm_request_logs
# Default columns:
# - request_id
# - created_at
# - model_name
# - provider
# - total_cost
# - input_tokens
# - output_tokens
# - total_tokens
# - latency_ms
# - status
# - request_input
# - request_output
# - metadata
# - langfuse_trace_id
# - langfuse_observation_id

# Optional mapping override for an existing non-canonical LiteLLM table
# LITELLM_LOG_TABLE=LiteLLM_SpendLogs
# LITELLM_ID_COLUMN=request_id
# LITELLM_CREATED_AT_COLUMN=startTime
# LITELLM_MODEL_COLUMN=model
# LITELLM_COST_COLUMN=spend
# LITELLM_PROVIDER_COLUMN=custom_llm_provider
# LITELLM_INPUT_TOKENS_COLUMN=prompt_tokens
# LITELLM_OUTPUT_TOKENS_COLUMN=completion_tokens
# LITELLM_TOTAL_TOKENS_COLUMN=total_tokens
# LITELLM_LATENCY_MS_COLUMN=end_to_end_latency_ms
# LITELLM_STATUS_COLUMN=status
# LITELLM_INPUT_COLUMN=request
# LITELLM_OUTPUT_COLUMN=response
# LITELLM_METADATA_COLUMN=metadata
# LITELLM_LANGFUSE_TRACE_ID_COLUMN=langfuse_trace_id
# LITELLM_LANGFUSE_OBSERVATION_ID_COLUMN=langfuse_observation_id
